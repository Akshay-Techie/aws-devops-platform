# ============================================================
# .env.example — Environment variables reference
#
# COPY THIS FILE:
#   cp .env.example .env
#
# NEVER COMMIT .env TO GIT — it's in .gitignore
#
# HOW THESE GET INJECTED:
#   Local dev  → python-dotenv reads .env file
#   Docker     → docker run -e APP_ENV=production ...
#   Kubernetes → ConfigMap (non-secret) / Secret (sensitive)
#   Jenkins    → Injected via Jenkinsfile environment block
# ============================================================

# ── Application ────────────────────────────────────────────
APP_ENV=development
APP_VERSION=1.0.0
PORT=5000

# Enable Flask debug mode ONLY in local development
# NEVER set to true in Docker/K8s/production
FLASK_DEBUG=true

# ── ML Model ───────────────────────────────────────────────
MODEL_NAME=mlops-demo-model
MODEL_VERSION=v1.0

# ── Kubernetes (injected by K8s Downward API) ──────────────
# Do NOT set these manually — K8s sets them automatically
# K8S_NAMESPACE=production
# K8S_POD_NAME=myapp-deployment-7d9f4b-xk2p9
# K8S_NODE_NAME=ip-10-0-1-45.ec2.internal
