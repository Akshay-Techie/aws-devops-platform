// ============================================================
// Jenkinsfile — Future MLOps Architect | Project-05
// Location: jenkins/Jenkinsfile
//
// HOW THIS WORKS:
// Every time you push code to GitHub, GitHub sends a webhook
// to Jenkins. Jenkins runs this file top to bottom.
// If any stage fails, the whole pipeline stops and rolls back.
// ============================================================

pipeline {

    // 'agent any' means run this pipeline on any available
    // Jenkins worker. Since we only have one Jenkins (VBox),
    // it runs directly on your Ubuntu machine.
    agent any

    // ── Environment Variables ─────────────────────────────
    // These variables are available in every stage below.
    // Think of them as global constants for this pipeline.
    environment {

        // AWS region where ECR and K8s cluster live
        AWS_REGION = "ap-south-1"

        // credentials() reads from Jenkins credentials store
        // We added AWS_ACCOUNT_ID as a secret text credential
        AWS_ACCOUNT_ID = credentials('AWS_ACCOUNT_ID')

        // ECR repository name we created earlier
        ECR_REPO = "akshaytechie/aws-devops-platform"

        // BUILD_NUMBER is auto-incremented by Jenkins
        // Build 1 → tag :1, Build 2 → tag :2 etc.
        // This ensures every build creates a unique image tag
        // so we can roll back to any previous version
        IMAGE_TAG = "${BUILD_NUMBER}"

        // Full ECR image URI — assembled from above variables
        // Example: 793433927733.dkr.ecr.ap-south-1.amazonaws.com/akshaytechie/aws-devops-platform:5
        ECR_IMAGE = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPO}:${IMAGE_TAG}"

        // Helm release name — must match what we deployed earlier
        // helm upgrade uses this to find the existing deployment
        HELM_RELEASE = "akshaytechie-app"

        // Kubernetes namespace where the app is deployed
        K8S_NAMESPACE = "default"
    }

    stages {

        // ══════════════════════════════════════════════════
        // STAGE 1 — CHECKOUT
        // Jenkins clones your GitHub repository to its
        // workspace on the Jenkins machine.
        // Every build starts fresh with latest code.
        // ══════════════════════════════════════════════════
        stage('Checkout') {
            steps {
                // checkout scm uses the Git repo configured
                // in the pipeline job settings (SCM section)
                checkout scm

                // Print last 3 commits so we know what changed
                sh 'git log --oneline -3'
            }
        }

        // ══════════════════════════════════════════════════
        // STAGE 2 — TEST
        // Run pytest unit tests BEFORE building the image.
        // WHY? Fail fast — don't waste time building and
        // pushing an image if the code is broken.
        // If tests fail → pipeline stops here, no deployment.
        // ══════════════════════════════════════════════════
        stage('Test') {
            steps {
                // dir() changes into the docker/app directory
                // same as: cd docker/app
                dir('docker/app') {
                    sh '''
                        pip install flask pytest --quiet --break-system-packages
                        export PATH=$PATH:/var/lib/jenkins/.local/bin
                        pytest test_app.py -v --tb=short
                    '''
                }
            }
        }

        // ══════════════════════════════════════════════════
        // STAGE 3 — BUILD DOCKER IMAGE
        // Build a new Docker image with the ECR tag.
        // IMAGE_TAG = BUILD_NUMBER so each build is unique.
        //
        // Example:
        //   Build 1 → image tagged :1
        //   Build 2 → image tagged :2
        //   If build 2 breaks, helm rollback goes to :1
        // ══════════════════════════════════════════════════
        stage('Build Docker Image') {
            steps {
                dir('docker/app') {
                    // -t tags the image with the full ECR URI
                    // . means use Dockerfile in current directory
                    sh "docker build -t ${ECR_IMAGE} ."
                }
            }
        }

        // ══════════════════════════════════════════════════
        // STAGE 4 — PUSH TO ECR
        // Push the Docker image to AWS ECR so Kubernetes
        // can pull it on the worker node.
        //
        // FLOW:
        //   1. Get ECR login token (valid 12 hours)
        //   2. docker login to ECR
        //   3. docker push image to ECR
        // ══════════════════════════════════════════════════
        stage('Push to ECR') {
            steps {
                // withCredentials safely injects secrets as
                // environment variables. They never appear
                // in Jenkins logs — shown as **** instead.
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID',     variable: 'AWS_KEY'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET')
                ]) {
                    sh '''
                        export AWS_ACCESS_KEY_ID=$AWS_KEY
                        export AWS_SECRET_ACCESS_KEY=$AWS_SECRET
                        export AWS_DEFAULT_REGION=ap-south-1

                        aws ecr get-login-password --region ap-south-1 | \
                            docker login \
                            --username AWS \
                            --password-stdin \
                            793433927733.dkr.ecr.ap-south-1.amazonaws.com

                        docker push ${ECR_IMAGE}
                    '''
                }
            }
        }

        // ══════════════════════════════════════════════════
        // STAGE 5 — UPDATE ECR SECRET
        // The ECR login token expires every 12 hours.
        // Kubernetes uses a Secret to pull images from ECR.
        // We refresh this secret on every deployment so
        // Kubernetes always has a valid token to pull images.
        //
        // FLOW:
        //   1. Delete old ecr-secret (ignore if not exists)
        //   2. Create fresh ecr-secret with new token
        // ══════════════════════════════════════════════════
        stage('Update ECR Secret') {
            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID',     variable: 'AWS_KEY'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET')
                ]) {
                    sh '''
                        export AWS_ACCESS_KEY_ID=$AWS_KEY
                        export AWS_SECRET_ACCESS_KEY=$AWS_SECRET
                        export AWS_DEFAULT_REGION=ap-south-1

                        kubectl delete secret ecr-secret \
                            --ignore-not-found \
                            -n ${K8S_NAMESPACE}

                        kubectl create secret docker-registry ecr-secret \
                            --docker-server=793433927733.dkr.ecr.ap-south-1.amazonaws.com \
                            --docker-username=AWS \
                            --docker-password=$(aws ecr get-login-password --region ap-south-1) \
                            --namespace=${K8S_NAMESPACE}
                    '''
                }
            }
        }

        // ══════════════════════════════════════════════════
        // STAGE 6 — DEPLOY WITH HELM
        // helm upgrade --install does two things:
        //   - If release EXISTS → upgrade to new image tag
        //   - If release NOT EXISTS → fresh install
        //
        // --atomic means:
        //   If deployment fails → automatically rollback
        //   to previous working version
        //
        // --timeout 120s means:
        //   Wait max 2 minutes for pods to become Ready
        //   If pods don't start in time → rollback
        //
        // --set image.tag overrides values.yaml at runtime
        //   So each build deploys its own unique image tag
        // ══════════════════════════════════════════════════
        stage('Deploy with Helm') {
            steps {
                sh '''
                    helm upgrade --install ${HELM_RELEASE} \
                        ~/helm/akshaytechie-app \
                        --namespace ${K8S_NAMESPACE} \
                        --set image.tag=${IMAGE_TAG} \
                        --set image.repository=793433927733.dkr.ecr.ap-south-1.amazonaws.com/akshaytechie/aws-devops-platform \
                        --atomic \
                        --timeout 120s
                '''
            }
        }

        // ══════════════════════════════════════════════════
        // STAGE 7 — SMOKE TEST
        // After deployment, verify the app is actually
        // responding correctly via the ALB.
        //
        // curl -f means:
        //   If HTTP response is not 200 → exit with error
        //   This causes Jenkins to mark the build as FAILED
        //
        // sleep 20 gives pods time to:
        //   - Pull the image from ECR
        //   - Start the container
        //   - Pass readiness probe
        //   - Register with the service
        // ══════════════════════════════════════════════════
        stage('Smoke Test') {
            steps {
                sh '''
                    sleep 20
                    curl -f http://akshaytechie-alb-794315555.ap-south-1.elb.amazonaws.com/health
                    echo "Smoke test passed!"
                '''
            }
        }
    }

    // ══════════════════════════════════════════════════════
    // POST ACTIONS
    // These run after all stages complete regardless of result
    //
    // success → runs only if ALL stages passed
    // failure → runs only if ANY stage failed
    // always  → runs no matter what (cleanup)
    // ══════════════════════════════════════════════════════
    post {

        success {
            echo "Pipeline SUCCESS - Build ${BUILD_NUMBER} deployed!"
        }

        failure {
            // helm rollback 0 means rollback to last good revision
            // || true means don't fail if rollback itself fails
            sh 'helm rollback ${HELM_RELEASE} 0 || true'
        }

        always {
            // Remove dangling images to free disk space
            // Jenkins builds accumulate images over time
            sh 'docker image prune -f || true'
        }
    }
}